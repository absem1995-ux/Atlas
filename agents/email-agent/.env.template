# Email Agent Configuration

# Mode
MOCK_MODE=true                          # Set to true for testing without real SMTP
LOG_LEVEL=info                          # debug, info, warn, error
PORT=3000

# Provider Selection
EMAIL_PROVIDER=sendgrid                 # sendgrid, smtp, aws_ses

# SendGrid (if using SendGrid)
SENDGRID_API_KEY=

# SMTP (if using generic SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# AWS SES (if using AWS SES)
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email Configuration
FROM_EMAIL=noreply@yourdomain.com
REPLY_TO_EMAIL=support@yourdomain.com

# Message Queue (Redis)
REDIS_URL=redis://localhost:6379
REDIS_DB=1

# Database (PostgreSQL/Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/agents_db

# Tracking & Webhooks
TRACKING_WEBHOOK_SECRET=your-webhook-secret-here
TRACKING_WEBHOOK_URL=https://yourdomain.com/webhooks/email

# Rate Limiting
RATE_LIMIT_PER_HOUR=50
RATE_LIMIT_PER_DAY=1000

# Guardrails
BULK_SEND_THRESHOLD=500
BULK_SEND_ESCALATE_AT=1000

# Audit Logging
AUDIT_LOG_RETENTION_DAYS=90

# Debug
DEBUG=email:*                           # Enable debug logging
VERBOSE=false
