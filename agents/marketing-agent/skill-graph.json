  "workflow": {
    "name": "Marketing Automation Workflow",
    "description": "Daily content generation, posting, and analytics",
    "stages": [
      {
        "stage": "discovery",
        "parallel": false,
        "skills": ["marketing-discover"],
        "optional": true,
        "schedule": "weekly monday 08:00 UTC",
        "description": "Research competitors and trends (optional)"
      },
      {
        "stage": "generation",
        "parallel": false,
        "skills": ["atlas-generate"],
        "required": true,
        "schedule": "daily 10:00 UTC (or on-demand)",
        "description": "Generate AI images and content hooks"
      },
      {
        "stage": "adaptation",
        "parallel": true,
        "skills": ["atlas-adapt-tiktok", "atlas-adapt-instagram", "atlas-adapt-youtube"],
        "required": [true, true, false],
        "schedule": "immediately after generation",
        "parallelizationNote": "All adapts run simultaneously (1-2 min total, not 3-6)",
        "description": "Format content for each platform (TikTok, Instagram, YouTube)"
      },
      {
        "stage": "distribution",
        "parallel": false,
        "skills": ["atlas-schedule"],
        "required": true,
        "schedule": "immediately after adaptation",
        "description": "Schedule all adapted content to platforms"
      },
      {
        "stage": "monitoring",
        "parallel": false,
        "skills": ["marketing-collect"],
        "optional": false,
        "schedule": "daily 00:00 UTC",
        "description": "Collect analytics from all platforms"
      },
      {
        "stage": "analysis",
        "parallel": false,
        "skills": ["marketing-analyze"],
        "optional": false,
        "schedule": "daily 05:15 UTC (after collection)",
        "description": "Analyze performance, identify winners/losers"
      },
      {
        "stage": "reporting",
        "parallel": true,
        "skills": ["marketing-report", "email-management"],
        "optional": false,
        "schedule": "daily 05:30 UTC (after analysis)",
        "parallelizationNote": "Send report and email simultaneously",
        "description": "Generate digest and send to user"
      }
    ]
  },

