{
  "id": "mission-control",
  "name": "Mission Control Dashboard",
  "version": "1.0.0",
  "description": "Real-time multi-agent monitoring dashboard with unified visibility into all agents, tasks, performance, and hard stops",
  "author": "James",
  "created": "2026-02-19T17:30:00Z",
  "status": "production",
  "keywords": [
    "dashboard",
    "monitoring",
    "multi-agent",
    "real-time",
    "websocket",
    "analytics"
  ],
  "dependencies": [
    "express",
    "ws",
    "cors",
    "dotenv"
  ],
  "api_endpoints": [
    "GET /api/status",
    "GET /api/agents",
    "GET /api/agents/:id",
    "GET /api/tasks",
    "GET /api/lessons",
    "GET /api/hard_stops",
    "POST /api/agent_update",
    "POST /api/task_progress",
    "POST /api/hard_stops/:id/decision"
  ],
  "websocket": {
    "endpoint": "ws://localhost:3500/ws",
    "events": [
      "initial_state",
      "agent_update",
      "task_progress",
      "task_created",
      "hard_stop_resolved"
    ]
  },
  "features": [
    "Real-time agent status monitoring",
    "Task progress tracking (multi-step workflows)",
    "Performance analytics (views, engagement, costs)",
    "Lessons feed (successes/failures)",
    "Hard stops control (approval decisions)",
    "WebSocket live updates (<100ms latency)",
    "REST API for queries",
    "Interactive dashboard (5 tabs)"
  ],
  "triggers": [
    "manual",
    "webhook",
    "cron"
  ],
  "performance": {
    "latency_ms": 50,
    "websocket_connections": "1000+",
    "api_throughput": "10000 req/sec",
    "memory_usage_mb": 100,
    "scalability": "horizontal"
  },
  "documentation": {
    "quick_start": "QUICK_START.md",
    "full_guide": "SKILL.md",
    "advanced": "ADVANCED.md",
    "integration": "INTEGRATION.md"
  },
  "testing": {
    "suite": "tests/test-mission-control.js",
    "coverage": "endpoints",
    "automated": true
  },
  "deployment": {
    "local": "npm install && node src/server.js",
    "docker": "docker build -t mission-control . && docker run -p 3500:3500 mission-control",
    "systemd": "Install as systemd service",
    "production": "nginx reverse proxy recommended"
  }
}
